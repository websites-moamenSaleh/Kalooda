# Copy to .env.local and fill in values.
# Never commit .env.local — it is gitignored.
# Every PR that adds a new env var must update this file.

# ─── Supabase ────────────────────────────────────────────────────────────────
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # server-side only — never expose to client

# ─── Google Maps ─────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
# Restrict this key to your domain(s) in Google Cloud Console to prevent abuse.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# ─── Sentry ──────────────────────────────────────────────────────────────────
# sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN="https://your-key@oXXX.ingest.sentry.io/XXX"
# sentry.io → Settings → Auth Tokens → Create Token (scopes: project:read, release:admin)
# Build-time only — used by withSentryConfig to upload source maps. Never expose to client.
SENTRY_AUTH_TOKEN="sntryu_..."
SENTRY_ORG="vanguardt"
SENTRY_PROJECT="javascript-nextjs"

# SMS provider for phone OTP verification (src/lib/sms.ts)
# Wire up your chosen provider there, then add its credentials here.
# SMS_PROVIDER=        # e.g. twilio, aws-sns, vonage
# SMS_FROM_NUMBER=     # your SMS-capable sender number or ID

# One-off Tokyo → Frankfurt migration (scripts/migrate-supabase-region.mjs)
# MIGRATE_SOURCE_URL=
# MIGRATE_SOURCE_SERVICE_ROLE=
# MIGRATE_TARGET_URL=
# MIGRATE_TARGET_SERVICE_ROLE=
