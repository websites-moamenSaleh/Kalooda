# Copy to .env.local and fill in values from Supabase → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Optional: AI chatbot
# OPENAI_API_KEY=

# SMS provider for phone OTP verification (src/lib/sms.ts)
# Wire up your chosen provider there, then add its credentials here.
# SMS_PROVIDER=        # e.g. twilio, aws-sns, vonage
# SMS_FROM_NUMBER=     # your SMS-capable sender number or ID

# One-off Tokyo → Frankfurt migration (scripts/migrate-supabase-region.mjs)
# MIGRATE_SOURCE_URL=
# MIGRATE_SOURCE_SERVICE_ROLE=
# MIGRATE_TARGET_URL=
# MIGRATE_TARGET_SERVICE_ROLE=
